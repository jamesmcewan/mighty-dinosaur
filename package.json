{
	"name": "mighty-dinosaur",
	"version": "15.1.2",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jamesmcewan/mighty-dinosaur.git"
	},
	"bugs": {
		"url": "https://github.com/jamesmcewan/mighty-dinosaur/issues"
	},
	"homepage": "https://github.com/jamesmcewan/mighty-dinosaur",
	"license": "MIT",
	"packageManager": "bun@1.3.10",
	"type": "module",
	"scripts": {
		"build": "bunx --bun astro build",
		"dev": "bunx --bun astro dev",
		"check": "oxfmt --check && oxlint --ignore-path=.gitignore && bunx --bun astro check",
		"fix": "oxlint --fix --ignore-path=.gitignore && oxfmt",
		"astro:check": "bunx --bun astro check",
		"lint:check": "oxlint --ignore-path=.gitignore",
		"lint:fix": "oxlint --fix --ignore-path=.gitignore",
		"format:write": "oxfmt",
		"format:check": "oxfmt --check",
		"prepare": "is-ci || lefthook install",
		"preview": "bunx --bun astro preview",
		"update-dependencies": "bunx @astrojs/upgrade && bun update"
	},
	"dependencies": {
		"@astrojs/mdx": "5.0.2",
		"@astrojs/rss": "4.0.17",
		"@tailwindcss/typography": "0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"astro": "6.0.7",
		"markdown-it": "14.1.1",
		"tailwindcss": "4.1.17"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.8",
		"@types/markdown-it": "14.1.2",
		"is-ci": "4.1.0",
		"lefthook": "2.0.7",
		"oxfmt": "0.15.0",
		"oxlint": "1.31.0",
		"typescript": "^5.9.3"
	},
	"trustedDependencies": ["esbuild", "lefthook", "sharp"]
}
