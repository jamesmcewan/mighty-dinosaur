---
import ElsewhereBlock from "@/components/block/elsewhere-block.astro"
import GridBlock from "@/components/block/grid-block.astro"
import MainBlock from "@/components/block/main-block.astro"
import MakerBlock from "@/components/block/maker-block.astro"
import PagesBlock from "@/components/block/pages-block.astro"
import RecentPostsBlock from "@/components/block/recent-posts-block.astro"
import getElsewhere from "@/data/get-elsewhere"
import getPage from "@/data/get-page"
import getPages from "@/data/get-pages"
import getPosts from "@/data/get-posts"
import TwoColumnLayout from "@/layouts/two-column-layout.astro"

const { description, title, Content, decoration, url } = await getPage("index")
const pages = await getPages()
const posts = await getPosts(5)
const elsewhere = await getElsewhere()
---

<TwoColumnLayout {description} {title} {decoration} {url}>
  <GridBlock>
    <MainBlock {title}>
      <Content />
    </MainBlock>
    <PagesBlock {pages} />
    <RecentPostsBlock {posts} />
    <MakerBlock />
    <ElsewhereBlock {elsewhere} />
  </GridBlock>
</TwoColumnLayout>
