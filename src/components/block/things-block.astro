---
import { getCollection } from "astro:content"

const things = await getCollection("things")

const categoryOrder = ["clothing", "electronics", "daily-carry"] as const

type Category = (typeof categoryOrder)[number]

const categoryLabels: Record<Category, string> = {
  clothing: "Clothing",
  electronics: "Electronics",
  "daily-carry": "Daily Carry",
}

const groupedThings = categoryOrder.map((category) => ({
  category,
  label: categoryLabels[category],
  items: things.filter((thing) => thing.data.category === category),
}))
---

<section class="not-prose space-y-12">
  {
    groupedThings.map((group) => (
      <div class="space-y-4">
        <h2 class="text-2xl font-bold">{group.label}</h2>

        <p class="text-gray-600 dark:text-gray-400">
          {group.category === "clothing" &&
            "I basically wear the same thing every day. Some times varied, but not often."}
          {group.category === "electronics" &&
            "These get the most day to day use."}
          {group.category === "daily-carry" &&
            "Never leave without."}
        </p>

        <table class="w-full border-collapse font-mono text-sm">
          <thead>
            <tr class="border-b-2 border-current">
              <th class="py-2 pr-4 text-left font-bold">Item</th>
              <th class="py-2 pr-4 text-left font-bold">Type</th>
              <th class="py-2 pr-4 text-left font-bold">Manufacturer</th>
              <th class="py-2 text-left font-bold">Comments</th>
            </tr>
          </thead>
          <tbody>
            {group.items.map((thing) => (
              <tr class="border-b border-gray-300 dark:border-gray-700">
                <td class="py-3 pr-4 text-nowrap">{thing.data.item}</td>
                <td class="py-3 pr-4 text-nowrap">{thing.data.type}</td>
                <td class="py-3 pr-4">{thing.data.manufacturer}</td>
                <td class="py-3 break-keep text-gray-600 dark:text-gray-400">
                  {thing.data.comments}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ))
  }
</section>
