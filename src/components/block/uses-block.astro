---
import { getCollection } from "astro:content"

const uses = await getCollection("uses")

const categoryOrder = [
  "setup",
  "editor",
  "ai",
  "browsers",
  "graphics",
  "built-with",
] as const

type Category = (typeof categoryOrder)[number]

const categoryLabels: Record<Category, string> = {
  setup: "Setup",
  editor: "Editor",
  ai: "AI",
  browsers: "Browsers",
  graphics: "Graphics",
  "built-with": "Built With",
}

const groupedUses = categoryOrder.map((category) => ({
  category,
  label: categoryLabels[category],
  items: uses.filter((use) => use.data.category === category),
}))

const setupItems = groupedUses.find((g) => g.category === "setup")
const editorItems = groupedUses.find((g) => g.category === "editor")
const aiItems = groupedUses.find((g) => g.category === "ai")
const browsersItems = groupedUses.find((g) => g.category === "browsers")
const graphicsItems = groupedUses.find((g) => g.category === "graphics")
const builtWithItems = groupedUses.find((g) => g.category === "built-with")
---

<section class="prose prose-xl font-rethink text-tn-text prose-headings:font-cartridgerough prose-headings:text-tn-text prose-headings:uppercase prose-h2:text-tn-green prose-strong:text-tn-red0 prose-img:rounded-xl space-y-12">
  <p>
    For the last twenty or so years, I've been a Mac person, prior to that, a
    die-hard PC fan, but I fell in love with Unix-flavoured operating systems.
  </p>

