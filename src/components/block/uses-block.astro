---
import { getCollection } from "astro:content"

const categoryOrder = [
  "setup",
  "editor",
  "ai",
  "browsers",
  "graphics",
  "built-with",
] as const

type Category = (typeof categoryOrder)[number]

interface Props {
  category: Category
}

const { category } = Astro.props
const uses = await getCollection("uses")
const items = uses.filter((use) => use.data.category === category)
---

<div class="not-prose">
  <table class="w-full border-collapse font-mono text-sm">
    <thead>
      <tr class="border-b-2 border-current">
        <th class="py-2 pr-4 text-left font-bold">Item</th>
        <th class="py-2 pr-4 text-left font-bold">Type</th>
        <th class="py-2 pr-4 text-left font-bold">Manufacturer</th>
        <th class="py-2 text-left font-bold">Comments</th>
      </tr>
    </thead>
    <tbody>
      {items.map((use) => (
        <tr class="border-b border-gray-300 dark:border-gray-700">
          <td class="py-3 pr-4 text-nowrap">
            {use.data.url ? (
              <a
                class="text-tn-green/80 hover:text-tn-green transition-colors duration-200"
                href={use.data.url}
                target="_blank"
                rel="noopener noreferrer"
              >
                {use.data.item}
              </a>
            ) : (
              use.data.item
            )}
          </td>
          <td class="py-3 pr-4 text-nowrap">{use.data.type}</td>
          <td class="py-3 pr-4">{use.data.manufacturer}</td>
          <td class="py-3 break-keep text-gray-600 dark:text-gray-400">
            {use.data.comments}
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
