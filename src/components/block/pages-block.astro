---
import type { CollectionEntry } from "astro:content"
import SectionHeadingBlock from "@/components/block/section-heading-block.astro"

interface Props {
  pages: CollectionEntry<"pages">[]
}

const { pages }: Props = Astro.props
---

<section>
  <SectionHeadingBlock> Pages </SectionHeadingBlock>
  <ul class="grid grid-cols-2 gap-x-6 gap-y-2">
    {
      pages.map((page, pageIndex) => {
        const { title, permalink } = page.data
        const titleWords = title.split(" ")
        return (
          <li class="border-b border-tn-text/10">
            <a
              href={`/${permalink}/`}
              class="block py-1 transition-all duration-150 ease-in-out hover:brightness-110"
            >
              <h2 class="font-cartridgerough uppercase text-tn-orange/90 hover:text-tn-orange text-lg">
                {titleWords.map((word, index) => (
                  <span
                    style={{
                      viewTransitionName: `title-${permalink}-word-${index}`,
                    }}
                  >
                    {word}{index < titleWords.length - 1 ? " " : ""}
                  </span>
                ))}
              </h2>
            </a>
          </li>
        )
      })
    }
  </ul>
</section>
